{
  "name": "skill-gap-detection-backend",
  "version": "1.0.0",
  "description": "Backend for AI Skill Gap Detection platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/server.js",
    "lint": "biome lint src/",
    "format": "biome format src/",
    "check": "biome check src/",
    "check:fix": "biome check --fix src/",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed:job-postings": "ts-node -r tsconfig-paths/register src/scripts/seed-job-postings.ts"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "^1.6.19",
    "@langchain/google-genai": "^2.1.31",
    "@prisma/client": "^5.10.0",
    "axios": "^1.6.7",
    "better-auth": "^1.6.19",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",

    "pdf-parse": "^2.4.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",

    "@types/node": "^20.11.24",
    "@types/pdf-parse": "^1.1.5",
    "@types/uuid": "^11.0.0",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
